;;3060070:1: 이르면 올해안에 건설교통부와 환경부 ~, 지방자치단체 ~, 지역주민 등이 참여하는 민관합동기구인 ' ~지속가능 지역개발위원회 ~' ~가 공식 출범할 전망이다 ~.

(S (NP-SBJ *pro*)
   (VP (NP (S (S (NP-SBJ *pro*)
                 (ADJP 이르/VJ+으면/ECS))
              (NP-ADV 올해/NNC+안/NNC+에/PAD)
              (S (NP-SBJ (S (WHNP-1 *op*)
                            (S (NP-SBJ *T*-1)
                               (VP (NP (S (WHNP-2 *op*)
                                          (S (NP-SBJ (NP (NP 건설/NNC+교통부/NNC+과/PCJ)
                                                         (NP 환경부/NNC)
                                                         ,/SCM
                                                         (NP 지방/NNC+자치/NNC+단체/NNC)
                                                         ,/SCM
                                                         (NP 지역/NNC+주민/NNC))
                                                     (NP 등/NNX+이/PCA))
                                             (VP (NP-COMP *T*-2)
                                                 (VV 참여/NNC+하/XSV+는/EAN))))
                                       (NP 민관/NNC+합동/NNC+기구/NNC+이/CO+은/EAN)))))
                         (NP '/SLQ
                             지속/NNC+가능/NNC
                             지역/NNC+개발/NNC+위원회/NNC
                             '/SRQ
                             이/PCA))
                 (VP (NP-ADV 공식/NNC)
                     (VP (VV 출범/NNC+하/XSV+을/EAN)))))
           (NP 전망/NNC+이/CO+다/EFN)))
   ./SFN)

;;3060070:2: 김명자 환경부 장관은 6 일 과천청사 지하 대강당에서 건교부 직원 5 백여명을 대상으로 한 특별강연에서 한강수계 등지의 지역개발과 환경보전 문제를 다룰 상설기구로 ` ~지속가능 지역개발위원회 ~( ~가칭 ~) ~' ~의 신설을 제의했다 ~.

(S (NP-SBJ 김명자/NPR
           환경부/NNC
           장관/NNC+은/PAU)
   (VP (NP-ADV 6/NNU
               일/NNX)
       (NP-ADV 과천/NPR+청사/NNC
               지하/NNC
               대강당/NNC+에서/PAD)
       (NP-ADV (S (WHNP-1 *op*)
                  (S (NP-SBJ *T*-1)
                     (VP (NP-OBJ 건교부/NNC
                                 직원/NNC
                                 5/NNU
                                 백/NNU+여/XSF+명/NNX+을/PCA)
                         (VP (NP-COMP 대상/NNC+으로/PAD)
                             하/VV+은/EAN))))
               (NP 특별/NNC+강연/NNC+에서/PAD))
       (NP-ADV (S (WHNP-2 *op*)
                  (S (NP-SBJ *T*-2)
                     (VP (NP-OBJ (NP (NP 한강/NPR+수계/NNC)
                                     (NP 등지/NNX+의/PAN))
                                 (NP (NP (NP 지역/NNC+개발/NNC+과/PCJ)
                                         (NP 환경/NNC+보전/NNC))
                                     (NP 문제/NNC+을/PCA)))
                         다루/VV+을/EAN)))
               (NP 상설/NNC+기구/NNC+으로/PAD))
       (VP (NP-OBJ (NP `/SLQ
                       지속/NNC+가능/NNC
                       지역/NNC+개발/NNC+위원회/NNC
                       (PRN -LRB-/SLQ
                            가칭/NNC
                            -RRB-/SRQ)
                       '/SRQ
                       의/PAN)
                   (NP 신설/NNC+을/PCA))
           (VV 제의/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060070:3: 이 위원회는 건교부와 환경부 ~, 지자체 ~, 지역주민 대표들이 참여 ~, 지역개발 과정에서의 환경보전 방안을 협의하는 기구로 준농림지와 상수원 주변 지역 등지의 난개발 해소에 크게 기여할 것으로 기대된다 ~.

(S (NP-SBJ *pro*)
   (VP (NP-COMP (S (NP-SBJ 이/DAN
                           위원회/NNC+은/PAU)
                   (VP (NP-ADV (S (WHNP-1 *op*)
                                  (S (NP-SBJ (NP 건교부/NNC+과/PCJ)
                                             (NP 환경부/NNC)
                                             ,/SCM
                                             (NP 지자체/NNC)
                                             ,/SCM
                                             (NP 지역/NNC+주민/NNC
                                                 대표/NNC+들/XSF+이/PCA))
                                     (VP (S (NP-SBJ *pro*)
                                            (VP (NP-COMP *T*-1)
                                                (VV 참여/NNC)))
                                         ,/SCM
                                         (VP (NP-OBJ (NP 지역/NNC+개발/NNC
                                                         과정/NNC+에서/PAD+의/PAN)
                                                     (NP 환경/NNC+보전/NNC
                                                         방안/NNC+을/PCA))
                                             (VV 협의/NNC+하/XSV+는/EAN)))))
                               (NP 기구/NNC+으로/PAD))
                       (VP (NP-COMP (NP (NP (NP 준농림지/NNC+과/PCJ)
                                            (NP 상수원/NNC
                                                주변/NNC
                                                지역/NNC))
                                        (NP 등지/NNX+의/PAN))
                                    (NP 난개발/NNC
                                        해소/NNC+에/PAD))
                           (VP (ADVP (ADV 크/VJ+게/ECS))
                               (VP (VV 기여/NNC+하/XSV+을/EAN))))))
                (NP 것/NNX+으로/PAD))
       (VV 기대/NNC+되/XSV+는다/EFN))
   ./SFN)

;;3060070:4: 특히 건교부도 김 장관의 제의에 대해 매우 환영하는 입장이어서 위원회 출범시기가 한층 앞당겨질 수 있을 것으로 예상된다 ~.

(S (S (ADVP 특히/ADV)
      (S (NP-SBJ 건교부/NNC+도/PAU)
         (VP (S (NP-SBJ *pro*)
                (VP (NP-COMP (NP 김/NPR
                                 장관/NNC+의/PAN)
                             (NP 제의/NNC+에/PAD))
                    대하/VV+어/ECS))
             (VP (NP (S (NP-SBJ *pro*)
                        (VP (ADVP 매우/ADV)
                            (VP (NP-OBJ *pro*)
                                (VV 환영/NNC+하/XSV+는/EAN))))
                     (NP 입장/NNC+이/CO+어서/ECS))))))
   (S (NP-SBJ *pro*)
      (VP (NP-COMP (S (NP-SBJ 위원회/NNC
                              출범/NNC+시기/NNC+이/PCA)
                      (VP (VP (ADVP 한층/ADV)
                              (VP (VV 앞당기/VV+어지/XSV+을/EAN)))
                          (VX 수/NNX
                              있/VJ+을/EAN)))
                   (NP 것/NNX+으로/PAD))
          (VV 예상/NNC+되/XSV+는다/EFN)))
   ./SFN)

;;3060070:5: 김 장관은 김윤기 건교부 장관의 초청으로 마련된 이날 특강에서 준농림지 개발 허용으로 지난 94-98 년에 약 2 천 500 개 숙박업소와 1 만 7 천여개 음식점이 들어서는 등 여의도 면적의 130 배에 달하는 준농림지가 개발됐다고 지적했다 ~.

(S (NP-SBJ 김/NPR
           장관/NNC+은/PAU)
   (VP (NP-ADV (S (WHNP-1 *op*)
                  (S (NP-SBJ *T*-1)
                     (VP (NP-ADV (NP 김윤기/NPR
                                     건교부/NNC
                                     장관/NNC+의/PAN)
                                 (NP 초청/NNC+으로/PAD))
                         (VP (VV 마련/NNC+되/XSV+은/EAN)))))
               (NP 이날/NNC
                   특강/NNC+에서/PAD))
       (VP (S-COMP (NP-ADV 준농림지/NNC
                           개발/NNC
                           허용/NNC+으로/PAD)
                   (NP-ADV (S (NP-ADV 지난/DAN
                                      94/NNU+-/SSY+98/NNU
                                      년/NNX+에/PAD)
                              (S (NP-SBJ (NP 약/DAN
                                             2/NNU
                                             천/NNU
                                             500/NNU
                                             개/NNX
                                             숙박/NNC+업소/NNC+과/PCJ)
                                         (NP 1/NNU
                                             만/NNU
                                             7/NNU
                                             천/NNU+여/XSF+개/NNX
                                             음식점/NNC+이/PCA))
                                 (VP 들어서/VV+는/EAN)))
                           (NP 등/NNX))
                   (S (NP-SBJ (S (WHNP-2 *op*)
                                 (S (NP-SBJ *T*-2)
                                    (VP (NP-COMP (NP 여의도/NPR
                                                     면적/NNC+의/PAN)
                                                 (NP 130/NNU
                                                     배/NNX+에/PAD))
                                        달하/VV+는/EAN)))
                              (NP 준농림지/NNC+이/PCA))
                      (VP (VV 개발/NNC+되/XSV+었/EPF+다/EFN+고/PAD))))
           (VV 지적/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060070:6: 김 장관은 특히 과거의 개발행태가 수도권과 경부축에 집중되는 등 지역편중현상이 극심했다고 지적하고 이런 난개발 과정에서 파생되는 환경문제를 특정부처가 나서 해결하기에는 역부족이라며 건교부 관리들의 협력을 촉구했다 ~.

(S (NP-SBJ 김/NPR
           장관/NNC+은/PAU)
   (VP (VP (ADVP 특히/ADV)
           (VP (S-COMP (NP-SBJ (NP (S (NP-SBJ (NP 과거/NNC+의/PAN)
                                              (NP 개발/NNC+형태/NNC+이/PCA))
                                      (VP (NP-COMP (NP 수도권/NNC+과/PCJ)
                                                   (NP 경부/NNC+측/XSF+에/PAD))
                                          (VV 집중/NNC+되/XSV+는/EAN)))
                                   (NP 등/NNX))
                               (NP 지역/NNC+편중/NNC+현상/NNC+이/PCA))
                       (ADJP 극심하/VJ+었/EPF+다/EFN+고/PAD))
               (VV 지적/NNC+하/XSV+고/ECS)))
       (VP (S (NP-SBJ *pro*)
              (VP (S-COMP (NP-OBJ-1 (DANP 이런/DAN)
                                    (NP (S (WHNP-2 *op*)
                                           (S (NP-SBJ *T*-2)
                                              (VP (NP-COMP 난개발/NNC
                                                           과정/NNC+에서/PAD)
                                                  (VV 파생/NNC+되/XSV+는/EAN))))
                                        (NP 환경/NNC+문제/NNC+을/PCA)))
                          (S (NP-SBJ 특정/NNC+부처/NNC+이/PCA)
                             (VP (S (NP-SBJ *pro*)
                                    (VP 나서/VV+어/ECS))
                                 (VP (NP-OBJ *T*-1)
                                     (VV 해결/NNC+하/XSV+기/ENM+에/PAD+은/PAU)))))
                  (VP (NP 역부족/NNC+이/CO+라며/ECS))))
           (VP (NP-OBJ (NP 건교부/NNC
                           관리/NNC+들/XSF+의/PAN)
                       (NP 협력/NNC+을/PCA))
               (VV 촉구/NNC+하/XSV+었/EPF+다/EFN))))
   ./SFN)

;;3060070:7: 김 장관은 특히 대규모 댐건설과 간척사업 등 환경논리보다는 경제성 위주의 개발사업이 시행되는 과정에서 상당한 부작용이 초래되고 있다며 환경친화적인 개발과 관리가 병행돼야 한다고 설명했다 ~.

(S (NP-SBJ 김/NPR
           장관/NNC+은/PAU)
   (VP (S (ADVP 특히/ADV)
          (NP-ADV (S (NP-SBJ (NP (NP (NP 대규모/NNC)
                                     (NP (NP 댐/NNC+건설/NNC+과/PCJ)
                                         (NP 간척/NNC+사업/NNC)))
                                 (NP 등/NNX))
                             (NP (NP (NP 환경/NNC+논리/NNC+보다/PAD+은/PAU)
                                     (NP 경제성/NNC
                                         위주/NNC+의/PAN))
                                 (NP 개발/NNC+사업/NNC+이/PCA)))
                     (VP (VV 시행/NNC+되/XSV+는/EAN)))
                  (NP 과정/NNC+에서/PAD))
          (S (NP-SBJ (S (WHNP-1 *op*)
                        (S (NP-SBJ *T*-1)
                           (ADJP (VJ 상당/NNC+하/XSJ+은/EAN))))
                     (NP 부작용/NNC+이/PCA))
             (VP (VP (VV 초래/NNC+되/XSV+고/ECS))
                 있/VX+다며/ECS)))
       (VP (S-COMP (NP-SBJ (S (WHNP-2 *op*)
                              (S (NP-SBJ *T*-2)
                                 (VP (NP 환경/NNC+친화/NNC+적/XSF+이/CO+은/EAN))))
                           (NP (NP 개발/NNC+과/PCJ)
                               (NP 관리/NNC+이/PCA)))
                   (VP (VP (VV 병행/NNC+되/XSV+어야/ECS))
                       하/VX+는다/EFN+고/PAD))
           (VV 설명/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060070:8: 김 장관은 이어 제 4 차 국토종합계획 ~( ~2000-2020 ~) ~에는 환경친화적인 개발을 강조해 다행이라며 앞으로도 건교부와 환경부간의 협력체제가 더욱 강화돼야 할 것이라고 강조했다 ~.

(S (NP-SBJ 김/NPR
           장관/NNC+은/PAU)
   (VP (ADVP 이어/ADV)
       (S (S (NP-SBJ *pro*)
             (VP (NP-ADV 제/DAN
                         4/NNU
                         차/NNX
                         국토/NNC+종합/NNC+계획/NNC
                         (PRN -LRB-/SLQ
                              2000-2020/NNU
                              -RRB-/SRQ)
                         에/PAD+은/PAU)
                 (VP (NP-OBJ (S (WHNP-1 *op*)
                                (S (NP-SBJ *T*-1)
                                   (VP (NP 환경/NNC+친화/NNC+적/XSF+이/CO+은/EAN))))
                             (NP 개발/NNC+을/PCA))
                     (VV 강조/NNC+하/XSV+어/ECS))))
          (S (NP-SBJ *pro*)
             (VP (NP 다행/NNC+이/CO+라며/ECS))))
       (VP (S-COMP (NP-ADV 앞/NNC+으로/PAD+도/PAU)
                   (S (NP-SBJ (NP (NP 건교부/NNC+과/PCJ)
                                  (NP 환경부/NNC+간/XSF+의/PAN))
                              (NP 협력/NNC+체제/NNC+이/PCA))
                      (VP (VP (VP (ADVP 더욱/ADV)
                                  (VP (VV 강화/NNC+되/XSV+어야/ECS)))
                              하/VX+을/EAN)
                          (VX 것/NNX+이/CO+라/EFN+고/PAD))))
           (VV 강조/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060070:9: 김 장관은 또 매년 봄철마다 되풀이되는 황사현상과 관련해 중국 서부지역의 산림 조성에 참여하기로 하고 현재 정부 차원에서 타당성 조사를 실시하고 있다고 전했다 ~.

(S (NP-SBJ 김/NPR
           장관/NNC+은/PAU)
   (VP (ADVP 또/ADV)
       (S (NP-SBJ *pro*)
          (VP (NP-COMP (S (WHNP-1 *op*)
                          (S (NP-SBJ *T*-1)
                             (VP (NP-ADV 매년/NNC
                                         봄철/NNC+마다/PAU)
                                 (VP (VV 되풀이/NNC+되/XSV+는/EAN)))))
                       (NP 황사/NNC+현상/NNC+과/PAD))
              (VV 관련/NNC+하/XSV+어/ECS)))
       (VP (S-COMP (NP-SBJ *pro*)
                   (VP (VP (S-COMP (NP-SBJ *pro*)
                                   (VP (NP-COMP (NP 중국/NPR
                                                    서부/NNC+지역/NNC+의/PAN)
                                                (NP 산림/NNC
                                                    조성/NNC+에/PAD))
                                       (VV 참여/NNC+하/XSV+기/ENM+으로/PAD)))
                           하/VV+고/ECS)
                       (VP (VP (NP-ADV 현재/NNC)
                               (NP-ADV 정부/NNC
                                       차원/NNC+에서/PAD)
                               (VP (NP-OBJ 타당성/NNC
                                           조사/NNC+을/PCA)
                                   (VV 실시/NNC+하/XSV+고/ECS)))
                           있/VX+다/EFN+고/PAD)))
           전하/VV+었/EPF+다/EFN))
   ./SFN)

;;3060070:10: 최근 중국을 방문한 김 장관은 주룽지 ~( ~주용기 ~) 중국 총리와의 면담에서 주총리가 신장 ~( ~신강 ~) 위구르 자치구 우르마치에서 상해를 잇는 200 억달러 규모의 천연가스 수송관 건설 프로젝트에 한국기업의 참여를 요청했다고 밝혔다 ~.

(S (NP-SBJ (S (WHNP-1 *op*)
              (S (NP-SBJ *T*-1)
                 (VP (NP-ADV 최근/NNC)
                     (VP (NP-OBJ 중국/NPR+을/PCA)
                         (VV 방문/NNC+하/XSV+은/EAN)))))
           (NP 김/NPR
               장관/NNC+은/PAU))
   (VP (S-COMP (NP-ADV (NP 주룽지/NPR
                           (PRN -LRB-/SLQ
                                주용기/NPR
                                -RRB-/SRQ)
                           중국/NPR
                           총리/NNC+과/PAD+의/PAN)
                       (NP 면담/NNC+에서/PAD))
               (S (NP-SBJ 주/NPR+총리/NNC+이/PCA)
                  (VP (NP-OBJ (NP (NP (S (WHNP-2 *op*)
                                         (S (NP-SBJ *T*-2)
                                            (VP (NP-COMP (NP 신장/NPR
                                                             (PRN -LRB-/SLQ
                                                                  신강/NPR
                                                                  -RRB-/SRQ)
                                                             위구르/NPR
                                                             자치구/NNC)
                                                         (NP 우르마치/NPR+에서/PAD))
                                                (NP-OBJ 상해/NPR+을/PCA)
                                                잇/VV+는/EAN)))
                                      (NP (NP 200/NNU
                                              억/NNU+달러/NNX
                                              규모/NNC+의/PAN)
                                          (NP 천연가스/NNC
                                              수송관/NNC)))
                                  (NP 건설/NNC
                                      프로젝트/NNC+에/PAD))
                              (NP (NP 한국/NPR+기업/NNC+의/PAN)
                                  (NP 참여/NNC+을/PCA)))
                      (VV 요청/NNC+하/XSV+었/EPF+다/EFN+고/PAD))))
       밝히/VV+었/EPF+다/EFN)
   ./SFN)

;;3060071:11: 미국의 제너럴모터스 ~( ~GM ~) ~사는 6 일 아시아 ~, 태평양경제협력체 ~( ~APEC ~) 회원국내 중소 자동차부품업체 제품의 구매를 늘리기로 했다고 GM코리아가 발표했다 ~.

