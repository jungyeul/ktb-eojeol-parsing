                                               선/NNC+이/PCA)
                                      되/VV+을/EAN)))
                            (NP 것/NNX+으로/PAD))
                   보이/VV+는다/EFN)
               "/SRQ
               고/PAD)
       말하/VV+었/EPF+다/EFN)
   ./SFN)

;;3060077:33: 대우증권은 전력사업의 구조개편이 다시 추진될 경우 ~, 한국전력의 적정주가는 5 만원에 이를 것이라며 매수를 추천했다 ~.

(S (NP-SBJ 대우/NPR+증권/NNC+은/PAU)
   (VP (S (NP-ADV (S (NP-SBJ (NP 전력/NNC+사업/NNC+의/PAN)
                             (NP 구조/NNC+개편/NNC+이/PCA))
                     (VP (ADVP 다시/ADV)
                         (VP (VV 추진/NNC+되/XSV+을/EAN))))
                  (NP 경우/NNC))
          ,/SCM
          (S (NP-SBJ (NP 한국/NPR+전력/NNC+의/PAN)
                     (NP 적정/NNC+주가/NNC+은/PAU))
             (VP (VP (NP-COMP 5/NNU
                              만/NNU+원/NNX+에/PAD)
                     이르/VV+을/EAN)
                 (VX 것/NNX+이/CO+라며/ECS))))
       (VP (NP-OBJ 매수/NNC+을/PCA)
           (VV 추천/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060077:34: 대우증권은 6 일 영국의 송전 전문업체인 ' ~내셔널 그리드 ~( ~National Grid ~) ~' ~가 전력사업 구조개편 이후 한전의 모습과 매우 흡사하다며 한전의 올해 수정 EPS ~( ~주당 순이익 ~) 2 천 594 원에 내셔널 그리드의 상대 PER ~( ~주가 수익비율 ~) ~을 적용할 때 한전의 적정주가는 5 만원 수준이라고 평가했다 ~.

(S (NP-SBJ 대우/NPR+증권/NNC+은/PAU)
   (VP (NP-ADV 6/NNU
               일/NNX)
       (S (NP-SBJ (S (WHNP-1 *op*)
                     (S (NP-SBJ *T*-1)
                        (VP (NP (NP 영국/NPR+의/PAN)
                                (NP 송전/NNC
                                    전문/NNC+업체/NNC+이/CO+은/EAN)))))
                  (NP '/SLQ
                      내셔널/NPR
                      그리드/NPR
                      (PRN -LRB-/SLQ
                           National/NFW
                           Grid/NFW
                           -RRB-/SRQ)
                      '/SRQ
                      이/PCA))
          (ADJP (NP-COMP (NP (NP 전력/NNC+사업/NNC
                                 구조/NNC+개편/NNC
                                 이후/NNC)
                             (NP 한전/NPR+의/PAN))
                         (NP 모습/NNC+과/PAD))
                (ADJP (ADVP 매우/ADV)
                      (ADJP (VJ 흡사/NNC+하/XSJ+다며/ECS)))))
       (VP (S-COMP (NP-ADV (S (WHNP *op*)
                              (S (NP-SBJ *pro*)
                                 (VP (NP-COMP (NP 한전/NPR+의/PAN)
                                              (NP (NP 올해/NNC
                                                      수정/NNC
                                                      EPS/NFW
                                                      (PRN -LRB-/SLQ
                                                           주당/NNC
                                                           순이익/NNC
                                                           -RRB-/SRQ))
                                                  (NP 2/NNU
                                                      천/NNU
                                                      594/NNU
                                                      원/NNX+에/PAD)))
                                     (NP-OBJ (NP 내셔널/NPR
                                                 그리드/NPR+의/PAN)
                                             (NP 상대/NNC
                                                 PER/NFW
                                                 (PRN -LRB-/SLQ
                                                      주가/NNC
                                                      수익/NNC+비율/NNC
                                                      -RRB-/SRQ)
                                                 을/PCA))
                                     (VV 적용/NNC+하/XSV+을/EAN))))
                           (NP 때/NNC))
                   (S (NP-SBJ (NP 한전/NPR+의/PAN)
                              (NP 적정/NNC+주가/NNC+은/PAU))
                      (VP (NP 5/NNU
                              만/NNU+원/NNX
                              수준/NNC+이/CO+라/EFN+고/PAD))))
           (VV 평가/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060077:35: 대우증권은 또 전력산업 구조개편을 고려하지 않을 경우 한전의 적정주가는 3 만 5 천원 수준이라고 평가했다 ~.

(S (NP-SBJ 대우/NPR+증권/NNC+은/PAU)
   (VP (ADVP 또/ADV)
       (VP (S-COMP (NP-ADV (S (NP-SBJ *pro*)
                              (VP (VP (NP-OBJ 전력/NNC+산업/NNC
                                              구조/NNC+개편/NNC+을/PCA)
                                      (VV 고려/NNC+하/XSV+지/ECS))
                                  않/VX+을/EAN))
                           (NP 경우/NNC))
                   (S (NP-SBJ (NP 한전/NPR+의/PAN)
                              (NP 적정/NNC+주가/NNC+은/PAU))
                      (VP (NP 3/NNU
                              만/NNU
                              5/NNU
                              천/NNU+원/NNX
                              수준/NNC+이/CO+라/EFN+고/PAD))))
           (VV 평가/NNC+하/XSV+었/EPF+다/EFN)))
   ./SFN)

;;3060077:36: 한전의 주가는 이날 오후 2 시 30 분 현재 2 만 7 천 850 원이다 ~.

(S (NP-SBJ (NP 한전/NPR+의/PAN)
           (NP 주가/NNC+은/PAU))
   (VP (NP-ADV 이날/NNC
               오후/NNC
               2/NNU
               시/NNX
               30/NNU
               분/NNX
               현재/NNC)
       (VP (NP 2/NNU
               만/NNU
               7/NNU
               천/NNU
               850/NNU
               원/NNX+이/CO+다/EFN)))
   ./SFN)

;;3060079:37: 석유수출국기구 ~( ~OPEC ~) 회원국들은 오는 4 월 산유량을 하루 100 만배럴 가까이 늘릴 것이라고 OPEC 회원국 고위 관리가 6 일 밝혔다 ~.

(S (S-COMP-1 (NP-SBJ 석유/NNC+수출국/NNC+기구/NNC
                     (PRN -LRB-/SLQ
                          OPEC/NFW
                          -RRB-/SRQ)
                     회원국/NNC+들/XSF+은/PAU)
             (VP (VP (NP-ADV 오는/DAN
                             4/NNU
                             월/NNX)
                     (VP (NP-OBJ 산유량/NNC+을/PCA)
                         (VP (ADVP (NP-COMP 하루/NNC
                                            100/NNU
                                            만/NNU+배럴/NNX)
                                   가까이/ADV)
                             (VP 늘리/VV+을/EAN))))
                 (VX 것/NNX+이/CO+라/EFN+고/PAD)))
   (S (NP-SBJ OPEC/NFW
              회원국/NNC
              고위/NNC
              관리/NNC+이/PCA)
      (VP (NP-ADV 6/NNU
                  일/NNX)
          (VP (S-COMP *T*-1)
              밝히/VV+었/EPF+다/EFN)))
   ./SFN)

